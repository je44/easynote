<Window x:Class="EasyNote.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EasyNote"
        mc:Ignorable="d"
        Title="easy-note"
        Width="340"
        Height="520"
        MinWidth="280"
        MinHeight="300"
        MaxHeight="920"
        WindowStyle="None"
        ResizeMode="CanMinimize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        FontFamily="{StaticResource AppDisplayFont}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
        <local:StringNullOrEmptyToVisibilityConverter x:Key="StringNullOrEmptyToVisibilityConverter" />

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="#161D2A" />
            <Setter Property="BorderBrush" Value="#2CFFFFFF" />
            <Setter Property="Foreground" Value="#F3F6FC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="11">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1D2636" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#38FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#111823" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HideButtonStyle" BasedOn="{StaticResource IconButtonStyle}" TargetType="Button">
            <Setter Property="Width" Value="54" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="SettingsIconButtonStyle" BasedOn="{StaticResource IconButtonStyle}" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="11">
                            <Viewbox Width="16" Height="16">
                                <Canvas Width="20" Height="20">
                                    <Ellipse Canvas.Left="6" Canvas.Top="6" Width="8" Height="8"
                                             Stroke="{TemplateBinding Foreground}" StrokeThickness="1.6" />
                                    <Line X1="10" Y1="1.8" X2="10" Y2="4.1" Stroke="{TemplateBinding Foreground}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    <Line X1="10" Y1="15.9" X2="10" Y2="18.2" Stroke="{TemplateBinding Foreground}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    <Line X1="1.8" Y1="10" X2="4.1" Y2="10" Stroke="{TemplateBinding Foreground}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    <Line X1="15.9" Y1="10" X2="18.2" Y2="10" Stroke="{TemplateBinding Foreground}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    <Line X1="4.1" Y1="4.1" X2="5.8" Y2="5.8" Stroke="{TemplateBinding Foreground}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    <Line X1="14.2" Y1="14.2" X2="15.9" Y2="15.9" Stroke="{TemplateBinding Foreground}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    <Line X1="14.2" Y1="5.8" X2="15.9" Y2="4.1" Stroke="{TemplateBinding Foreground}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    <Line X1="4.1" Y1="15.9" X2="5.8" Y2="14.2" Stroke="{TemplateBinding Foreground}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1D2636" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#38FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#111823" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="14,0,14,1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#33FFFFFF" />
            <Setter Property="Foreground" Value="#8899BB" />
            <Setter Property="Background" Value="#16FFFFFF" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="Active">
                                <Setter TargetName="Root" Property="Background" Value="#44FFFFFF" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#66FFFFFF" />
                                <Setter Property="Foreground" Value="#EEEEFF" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#28FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CheckCircleButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#84A4FF" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Stroke="{TemplateBinding BorderBrush}"
                                     StrokeThickness="{TemplateBinding BorderThickness}"
                                     Fill="{TemplateBinding Background}" />
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PinBadgeButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Background" Value="#10FFFFFF" />
            <Setter Property="BorderBrush" Value="#18FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#F3F6FC" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <Viewbox Width="14" Height="14">
                                <Canvas Width="20" Height="20">
                                    <Path Stroke="{TemplateBinding Foreground}"
                                          StrokeThickness="1.5"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Data="M7.5,3.5 L12.5,3.5 L11.5,8.5 L14.5,11.5 L13,13 L10,10.2 L10,17 L8.8,17 L8.8,10.2 L6,13 L4.5,11.5 L7.5,8.5 Z" />
                                </Canvas>
                            </Viewbox>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FlatGlyphButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#DDE6FF" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InlineScrollBarRepeatButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InlineScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="MinHeight" Value="20" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="#66FFFFFF" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Width="4"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Stretch"
                                CornerRadius="2"
                                Background="{TemplateBinding Background}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#99FFFFFF" />
                </Trigger>
                <Trigger Property="IsDragging" Value="True">
                    <Setter Property="Background" Value="#CCFFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InlineScrollBarStyle" TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Width="{TemplateBinding Width}"
                              Background="Transparent">
                            <Border Width="2"
                                    HorizontalAlignment="Center"
                                    CornerRadius="1"
                                    Background="#14FFFFFF" />
                            <Track x:Name="PART_Track"
                                   Margin="0,2,0,2"
                                   Focusable="False"
                                   IsDirectionReversed="True"
                                   Orientation="Vertical"
                                   Minimum="{TemplateBinding Minimum}"
                                   Maximum="{TemplateBinding Maximum}"
                                   Value="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                   ViewportSize="{TemplateBinding ViewportSize}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource InlineScrollBarRepeatButtonStyle}"
                                                  Command="ScrollBar.PageUpCommand" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource InlineScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource InlineScrollBarRepeatButtonStyle}"
                                                  Command="ScrollBar.PageDownCommand" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#0CFFFFFF" />
            <Setter Property="BorderBrush" Value="#1AFFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#F3F6FC" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="CaretBrush" Value="#F3F6FC" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="VerticalContentAlignment" Value="Top" />
            <Setter Property="TextAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="0"
                                          Padding="0"
                                          VerticalAlignment="Top">
                                <ScrollViewer.Resources>
                                    <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource InlineScrollBarStyle}" />
                                </ScrollViewer.Resources>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type DatePickerTextBox}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#DEE7F7" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="DatePickerPopupButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#EAF1FF" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="0,11,11,0">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="14"
                                       Foreground="{TemplateBinding Foreground}"
                                       Text="&#xE787;" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#12FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#18FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DatePickerCalendarStyle" TargetType="Calendar">
            <Setter Property="Foreground" Value="#EAF1FF" />
            <Setter Property="Background" Value="#1A2434" />
            <Setter Property="BorderBrush" Value="#26FFFFFF" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="PopupActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="#12FFFFFF" />
            <Setter Property="BorderBrush" Value="#22FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#EAF1FF" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="999">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1AFFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DatePickerHostStyle" TargetType="DatePicker">
            <Setter Property="Foreground" Value="#DEE7F7" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Height" Value="36" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="SelectedDateFormat" Value="Short" />
            <Setter Property="CalendarStyle" Value="{StaticResource DatePickerCalendarStyle}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Grid x:Name="PART_Root"
                              SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="38" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.ColumnSpan="2"
                                    Background="#0CFFFFFF"
                                    BorderBrush="#1AFFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="12" />
                            <DatePickerTextBox x:Name="PART_TextBox"
                                               Grid.Column="0"
                                               Margin="14,0,0,0"
                                               VerticalAlignment="Center"
                                               VerticalContentAlignment="Center"
                                               Background="Transparent"
                                               BorderThickness="0"
                                               Foreground="#DEE7F7" />
                            <Button x:Name="PART_Button"
                                    Grid.Column="1"
                                    Style="{StaticResource DatePickerPopupButtonStyle}"
                                    Focusable="False"
                                    Foreground="#F3F6FC">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe UI Emoji"
                                           FontSize="14"
                                           Text="📅" />
                            </Button>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding ElementName=PART_Root}"
                                   PopupAnimation="Fade"
                                   StaysOpen="False">
                                <Border Margin="0,8,0,0"
                                        Padding="8"
                                        Background="#E61A2434"
                                        BorderBrush="#26FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="16">
                                    <StackPanel>
                                        <Calendar x:Name="PART_Calendar"
                                                  Width="248"
                                                  Style="{StaticResource DatePickerCalendarStyle}" />
                                        <DockPanel Margin="0,8,0,0"
                                                   LastChildFill="False">
                                            <Button DockPanel.Dock="Left"
                                                    Style="{StaticResource PopupActionButtonStyle}"
                                                    Click="TodayDateButton_Click"
                                                    Content="今天" />
                                            <Button DockPanel.Dock="Left"
                                                    Style="{StaticResource PopupActionButtonStyle}"
                                                    Click="ClearDateButton_Click"
                                                    Content="清除" />
                                            <Button DockPanel.Dock="Right"
                                                    Style="{StaticResource PopupActionButtonStyle}"
                                                    Margin="0"
                                                    Click="CloseDatePopupButton_Click"
                                                    Content="关闭" />
                                        </DockPanel>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="PART_Root" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SliderThumbStyle" TargetType="Thumb">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="Background" Value="#88A0FF" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Ellipse Width="14"
                                 Height="14"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Fill="{TemplateBinding Background}"
                                 Stroke="#DCE5FF"
                                 StrokeThickness="1.5" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OpacitySliderStyle" TargetType="Slider">
            <Setter Property="Height" Value="20" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="20">
                            <!-- 杞ㄩ亾鑳屾櫙 -->
                            <Border Height="3"
                                    VerticalAlignment="Center"
                                    Background="#22FFFFFF"
                                    CornerRadius="1.5" />
                            <!-- Track锛屽彧璐熻矗瀹氫綅 Thumb锛屼笉娓叉煋浠讳綍鑳屾櫙 -->
                            <Track x:Name="PART_Track"
                                   VerticalAlignment="Center"
                                   Height="20"
                                   Minimum="{TemplateBinding Minimum}"
                                   Maximum="{TemplateBinding Maximum}"
                                   Value="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Focusable="False"
                                                  IsTabStop="False"
                                                  VerticalAlignment="Center"
                                                  Height="3">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3"
                                                        VerticalAlignment="Center"
                                                        Background="#6F89FF"
                                                        CornerRadius="1.5" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SliderThumbStyle}"
                                           Focusable="False"
                                           IsTabStop="False" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Focusable="False"
                                                  IsTabStop="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="0,1,0,0" />
            <Setter Property="Background" Value="#6F8FF8" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#7D9AF9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#6284EE" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InlineActionButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#F6F8FD" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Height="{TemplateBinding Height}"
                                MinWidth="{TemplateBinding MinWidth}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarRepeatButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="#66FFFFFF" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Width="4"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Stretch"
                                CornerRadius="2"
                                Background="{TemplateBinding Background}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#99FFFFFF" />
                </Trigger>
                <Trigger Property="IsDragging" Value="True">
                    <Setter Property="Background" Value="#CCFFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GlassScrollBarStyle" TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="10" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Width="{TemplateBinding Width}"
                              Margin="0,4,0,4"
                              Background="Transparent">
                            <Border Width="2"
                                    HorizontalAlignment="Center"
                                    Background="#18FFFFFF"
                                    CornerRadius="999" />
                            <Track x:Name="PART_Track"
                                   Focusable="False"
                                   IsDirectionReversed="True"
                                   Orientation="{TemplateBinding Orientation}"
                                   Minimum="{TemplateBinding Minimum}"
                                   Maximum="{TemplateBinding Maximum}"
                                   Value="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                   ViewportSize="{TemplateBinding ViewportSize}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarRepeatButtonStyle}"
                                                  Command="ScrollBar.PageUpCommand" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource GlassScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarRepeatButtonStyle}"
                                                  Command="ScrollBar.PageDownCommand" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource GlassScrollBarStyle}" />

        <Style x:Key="OverlayScrollViewerStyle" TargetType="{x:Type ScrollViewer}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollViewer}">
                        <Grid Background="Transparent">
                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                    Margin="{TemplateBinding Padding}"
                                                    CanContentScroll="{TemplateBinding CanContentScroll}" />
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Width="6"
                                       Margin="0,2,-8,2"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Stretch"
                                       Minimum="0"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Value="{Binding VerticalOffset, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                       Style="{StaticResource InlineScrollBarStyle}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TodoListStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="False" />
            <Setter Property="Padding" Value="0,2,0,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="0">
                            <ScrollViewer Focusable="False"
                                          Style="{StaticResource OverlayScrollViewerStyle}"
                                          Padding="{TemplateBinding Padding}"
                                          HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                          VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}">
                                <ItemsPresenter />
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="20"
            BorderThickness="1"
            BorderBrush="#26FFFFFF"
            Background="#B8131B29">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="8" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Margin="14,10,14,0"
                  Background="Transparent"
                  PreviewMouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource TabButtonStyle}"
                            Margin="0,0,6,0"
                            Tag="{Binding PendingTabTag}"
                            Click="PendingTab_Click"
                            Content="待办" />
                    <Button Style="{StaticResource TabButtonStyle}"
                            Margin="0"
                            Tag="{Binding CompletedTabTag}"
                            Click="CompletedTab_Click"
                            Content="已办" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource SettingsIconButtonStyle}"
                            Content="⚙"
                            Click="SettingsButton_Click" />
                    <Button Style="{StaticResource HideButtonStyle}"
                            Margin="0"
                            Content="隐藏"
                            Click="HideButton_Click" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="14,10,14,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="14"
                        Margin="0,0,0,12"
                        CornerRadius="16"
                        Background="#10FFFFFF"
                        BorderBrush="#18FFFFFF"
                        BorderThickness="1"
                        Visibility="{Binding IsSettingsOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Foreground="#F3F6FC"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Text="设置" />
                            <Button Grid.Column="1"
                                    Width="24"
                                    Height="24"
                                    Style="{StaticResource FlatGlyphButtonStyle}"
                                    Foreground="#DDE6FF"
                                    FontSize="18"
                                    Content="✕"
                                    Click="SettingsCloseButton_Click" />
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="#BBC6DC"
                                       FontSize="12"
                                       Text="透明度" />
                            <Slider Grid.Column="1"
                                    Style="{StaticResource OpacitySliderStyle}"
                                    Margin="14,0,14,0"
                                    Minimum="35"
                                    Maximum="100"
                                    Value="{Binding OpacityPercent, Mode=TwoWay}" />
                            <TextBlock Grid.Column="2"
                                       VerticalAlignment="Center"
                                       Foreground="#F3F6FC"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Text="{Binding OpacityPercent, StringFormat={}{0:0}%}" />
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Padding="14"
                        Margin="0,0,0,12"
                        CornerRadius="16"
                        Background="#09FFFFFF"
                        BorderBrush="#1AFFFFFF"
                        BorderThickness="1"
                        Visibility="{Binding IsPendingView, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <Grid>
                            <Border Height="96"
                                    MaxHeight="96"
                                    Background="#0CFFFFFF"
                                    BorderBrush="#1AFFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="14,10">
                                <Grid>
                                    <TextBox Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="#F3F6FC"
                                             CaretBrush="#F3F6FC"
                                             FontSize="15"
                                             Padding="0"
                                             VerticalContentAlignment="Top"
                                             TextAlignment="Left"
                                             PreviewKeyDown="DraftTextBox_PreviewKeyDown"
                                             Text="{Binding DraftText, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Disabled" />
                                     <TextBlock VerticalAlignment="Top"
                                                HorizontalAlignment="Left"
                                                Foreground="#93A0BB"
                                                FontSize="15"
                                                TextAlignment="Left"
                                                IsHitTestVisible="False"
                                                Text="写点要做的事"
                                                Visibility="{Binding DraftText, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}}" />
                                </Grid>
                            </Border>
                        </Grid>

                        <Button Margin="0,12,0,0"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                Content="记下"
                                Click="AddButton_Click" />
                    </StackPanel>
                </Border>

                <Grid Grid.Row="2">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#BBC6DC"
                               FontSize="14"
                               Text="{Binding EmptyStateText}"
                               Visibility="{Binding HasVisibleItems, Converter={StaticResource InverseBoolToVisibilityConverter}}" />

                    <ListBox Style="{StaticResource TodoListStyle}"
                             ItemsSource="{Binding VisibleItems}"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Visibility="{Binding HasVisibleItems, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ListBox.OpacityMask>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#FFFFFFFF" Offset="0" />
                                <GradientStop Color="#FFFFFFFF" Offset="0.82" />
                                <GradientStop Color="#00FFFFFF" Offset="1" />
                            </LinearGradientBrush>
                        </ListBox.OpacityMask>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,10" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Focusable" Value="False" />
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:TodoItem}">
                                <Border x:Name="CardRoot"
                                        CornerRadius="14"
                                        Background="#10FFFFFF"
                                        BorderBrush="#1AFFFFFF"
                                        BorderThickness="1"
                                        PreviewMouseLeftButtonDown="TodoItem_MouseLeftButtonDown"
                                        PreviewMouseLeftButtonUp="TodoItem_MouseLeftButtonUp"
                                        MouseLeave="TodoItem_MouseLeave"
                                        Tag="{Binding}">
                                    <Grid x:Name="CardGrid">
                                        <Ellipse x:Name="PinMark"
                                                 Width="8"
                                                 Height="8"
                                                 Margin="16,12,0,0"
                                                 HorizontalAlignment="Left"
                                                 VerticalAlignment="Top"
                                                 Fill="#FFD86B"
                                                 Visibility="Collapsed" />

                                        <Grid x:Name="CardContent"
                                              Margin="16,16,16,10"
                                              MinHeight="52">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button Style="{StaticResource CheckCircleButtonStyle}"
                                                    Grid.Column="0"
                                                    Margin="0,0,14,0"
                                                    VerticalAlignment="Top"
                                                    Tag="{Binding}"
                                                    Click="ToggleDoneButton_Click">
                                                <TextBlock FontSize="11"
                                                           FontWeight="Bold"
                                                           Text="✓"
                                                           Visibility="{Binding CompletedAt, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            </Button>

                                            <Button x:Name="PinButtonLegacy"
                                                    Margin="0,10,12,0"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Top"
                                                    Panel.ZIndex="3"
                                                    Style="{StaticResource PinBadgeButtonStyle}"
                                                    Tag="{Binding}"
                                                    Click="PinButton_Click"
                                                    Visibility="Collapsed">
                                                <TextBlock Text="📌"
                                                           FontSize="11"
                                                           FontWeight="Bold" />
                                            </Button>

                                            <TextBlock Grid.Column="1"
                                                       Grid.Row="0"
                                                       Margin="0,0,42,15"
                                                       Foreground="#F3F6FC"
                                                       FontSize="15"
                                                       VerticalAlignment="Top"
                                                       TextAlignment="Left"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding Text}" />
                                            <TextBlock x:Name="SecondaryTextBlock"
                                                       Grid.Column="1"
                                                       Grid.Row="1"
                                                       Margin="0,0,52,0"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Bottom"
                                                       Foreground="#AEB9D3"
                                                       FontSize="10"
                                                       TextAlignment="Right"
                                                       Visibility="Collapsed"
                                                       Text="{Binding SecondaryText}" />
                                        </Grid>

                                        <TextBlock x:Name="SecondaryOverlayTextBlock"
                                                   Margin="0,0,14,8"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Bottom"
                                                   Foreground="#AEB9D3"
                                                   FontSize="9"
                                                   TextAlignment="Right"
                                                   Text="{Binding SecondaryText}" />

                                        <Button x:Name="PinButton"
                                                Margin="0,10,12,0"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Panel.ZIndex="6"
                                                Style="{StaticResource PinBadgeButtonStyle}"
                                                Tag="{Binding}"
                                                Click="PinButton_Click"
                                                Visibility="{Binding DataContext.IsPendingView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock Text="📌"
                                                       FontSize="11"
                                                       FontWeight="Bold" />
                                        </Button>

                                        <Border x:Name="DeleteOverlay"
                                                Panel.ZIndex="20"
                                                Background="#EE0E1620"
                                                CornerRadius="13"
                                                Visibility="Collapsed">
                                            <StackPanel VerticalAlignment="Center"
                                                        HorizontalAlignment="Center"
                                                        Margin="0">
                                                <TextBlock HorizontalAlignment="Center"
                                                           Foreground="#FFB8B8"
                                                           FontSize="12"
                                                           FontWeight="Bold"
                                                           Text="{Binding DataContext.DeleteOverlayText, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Center"
                                                            Margin="0,10,0,0">
                                                    <Button Style="{StaticResource InlineActionButtonStyle}"
                                                            Margin="0,0,8,0"
                                                            Background="#88C0392B"
                                                            BorderBrush="#AAC0392B"
                                                            Tag="{Binding}"
                                                            Click="DeleteConfirmButton_Click"
                                                            Content="删除" />
                                                    <Button Style="{StaticResource InlineActionButtonStyle}"
                                                            Background="#33FFFFFF"
                                                            BorderBrush="#44FFFFFF"
                                                            Tag="{Binding}"
                                                            Click="CancelDeleteButton_Click"
                                                            Content="撤销" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Pinned}" Value="True" />
                                            <Condition Binding="{Binding DataContext.IsPendingView, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="CardRoot" Property="Background" Value="#20FFD254" />
                                        <Setter TargetName="CardRoot" Property="BorderBrush" Value="#52FFD254" />
                                        <Setter TargetName="PinMark" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="PinButton" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="PinButton" Property="Background" Value="#2EFFD254" />
                                        <Setter TargetName="PinButton" Property="BorderBrush" Value="#66FFD254" />
                                        <Setter TargetName="PinButton" Property="Foreground" Value="#FFD86B" />
                                    </MultiDataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsMouseOver, ElementName=CardRoot}" Value="True" />
                                            <Condition Binding="{Binding DataContext.IsPendingView, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="CardRoot" Property="Background" Value="#14FFFFFF" />
                                        <Setter TargetName="CardRoot" Property="BorderBrush" Value="#24FFFFFF" />
                                        <Setter TargetName="PinButton" Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsMouseOver, ElementName=CardRoot}" Value="True" />
                                            <Condition Binding="{Binding Pinned}" Value="True" />
                                            <Condition Binding="{Binding DataContext.IsPendingView, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="CardRoot" Property="Background" Value="#24FFD254" />
                                        <Setter TargetName="CardRoot" Property="BorderBrush" Value="#68FFD254" />
                                    </MultiDataTrigger>
                                    <DataTrigger Binding="{Binding PendingDelete}" Value="True">
                                        <Setter TargetName="CardContent" Property="Opacity" Value="0" />
                                        <Setter TargetName="CardContent" Property="IsHitTestVisible" Value="False" />
                                        <Setter TargetName="SecondaryOverlayTextBlock" Property="Opacity" Value="0" />
                                        <Setter TargetName="PinMark" Property="Visibility" Value="Collapsed" />
                                        <Setter TargetName="PinButton" Property="Visibility" Value="Hidden" />
                                        <Setter TargetName="DeleteOverlay" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>

            <!-- 搴曢儴鎷栨嫿璋冩暣楂樺害鍖哄煙 -->
            <Border Grid.Row="2"
                    Background="Transparent"
                    Cursor="SizeNS"
                    MouseLeftButtonDown="ResizeGrip_MouseLeftButtonDown" />
        </Grid>
    </Border>
</Window>
