<Application x:Class="EasyNote.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="http://www.hardcodet.net/taskbar"
             xmlns:local="clr-namespace:EasyNote"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <FontFamily x:Key="AppDisplayFont">pack://application:,,,/Assets/Fonts/#Newsreader, Microsoft YaHei UI</FontFamily>
        <FontFamily x:Key="AppAccentFont">pack://application:,,,/Assets/Fonts/#Newsreader</FontFamily>
        <tb:TaskbarIcon x:Key="TrayIcon"
                        IconSource="/Assets/icon.ico"
                        ToolTipText="easy-note · 数据自动保存在本地">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu FontFamily="{StaticResource AppDisplayFont}">
                    <MenuItem Header="显示便签" Click="OnTrayShow" />
                    <MenuItem Header="固定到右上角" Click="OnTrayDock" />
                    <Separator/>
                    <MenuItem x:Name="AutostartMenuItem" Header="开机自启动" IsCheckable="True" Click="OnTrayAutostart" />
                    <Separator/>
                    <MenuItem Header="退出" Click="OnTrayQuit" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Application.Resources>
</Application>
